<configuration>
	<include resource="org/springframework/boot/logging/logback/defaults.xml"/>

	<property name="CONSOLE_LOG_PATTERN"
			  value="%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSS}){cyan} %clr(%5p) %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n" />

	<include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

	<!-- Deadlocks handled by @Retryable — suppress noise from Hibernate's jdbc error logger -->
	<logger name="org.hibernate.orm.jdbc.error" level="ERROR"/>

	<root level="INFO">
		<appender-ref ref="CONSOLE"/>
	</root>
</configuration>
